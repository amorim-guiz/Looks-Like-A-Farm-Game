pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
function _init()
	icrops()
	imoney()
	iplr()
	idays()
	itrans()
	state="play"
end

function _update()

	if state=="play" then
		uplr()
		uactions()
		udays()
	elseif state=="dead" then
		if	btnp(🅾️) then
			run()
		end
	end
	
end

function _draw()
 cls()
 
 if state=="play" then
	 map()
	 dplr()
	 print(flr(clock),88,114,10)
	 print(day,105,114,10)
	 print(carrots,41,114)
	 print(flr(plr.bat),72,114,10)
	 print(money,56,114,10)
	 print(seeds,25,114,10)
	 dtrans()
	elseif state=="dead" then
		print("ur dead,",50,50,10)
		print("press c to restart",28,60,10)
	elseif state=="timeout" then
		print("ur timed out,",40,50,10)
		print("press c to restart",28,60,10)
	end
	
end
-->8
-- player / mvmt / tile sel --

function iplr()

	plr={
		x=63,
		y=63,
		bat=99
	}

end

function uplr()

	if btn(➡️) then
		plr.x+=1
		drain("mvmt")
	end
	if btn(⬅️) then
		plr.x-=1
		drain("mvmt")
	end
	if btn(⬆️) then
		plr.y-=1
		drain("mvmt")
	end
	if btn(⬇️) then
		plr.y+=1
		drain("mvmt")
	end -- player mvmt --
	
	
	tile={
		x=flr((plr.x+6)/8),
		y=flr((plr.y+8)/8)
	}

end

function dplr()

	spr(4,tile.x*8,tile.y*8)
	spr(10,plr.x,plr.y)

	
--	print(tile.x) -- show tile x
--	print(tile.y) -- show tile y
end
-->8
-- actions --

function uactions()

	if btnp(❎) then
		local sp=mget(tile.x,tile.y)
		
		if fget(sp,0) then
			-- plant seeds --
			if seeds>0 then
				mset(tile.x,tile.y,33)
				drain("act")	
				seeds-=1
			end
		elseif fget(sp,1) then
			-- watering tile --
			mset(tile.x,tile.y,sp+16)
			drain("act")
			
		elseif fget(sp,3) then
			-- harvest carrot --
			mset(tile.x,tile.y,52)
			harvest()
			drain("act")
			
		elseif fget(sp,4) then
			-- day prog / bat charge --
			day+=1
			clock=24
			trans()
			grow()
			plr.bat=99
			
		elseif fget(sp,5) then
			-- buy seeds --
			if money>0 then
				money-=1
				seeds+=1
			end
					
		elseif fget(sp,6) then
			-- sell carrots --
			if carrots>0 then
				money+=3
				carrots-=1
			end
			
		end -- check tile then plant/water -- 
		
	end -- if button press --
end -- function end --
-->8
-- day cicle --

function idays()
	day=1
	clock=24
end

function udays()
 clock-=.03
 
 if clock<0 then
 	state="timeout"
 end
 
end


-- day cicle --

-- transition --
function itrans()
	ttime=128
end

function trans()
	ttime=0
end

function dtrans()
 ttime+=6
 if ttime<128 then
		rectfill(0,0,128,128-ttime,2)
	end
end
-- transition --

-->8
-- growing crops --

function grow()
	for tx = 0,15 do
		for ty = 0,15 do
			local sp=(mget(tx,ty))
			if fget(mget(tx,ty),2) then
				mset(tx,ty,sp-15)
			end -- if fget --
		end -- ty for --
	end -- tx for --
end
-->8
-- money and harvesting --

function icrops()
	
	carrots=0
	seeds=5
	
end

function imoney()
	money=12
end

function harvest()

	carrots+=1
	
end
-->8
-- battery stuff --

function drain(amt)

	if amt=="mvmt" then
		plr.bat-=.1
	elseif amt=="act" then
		plr.bat-=.5
	end -- battery cost --
	
	if plr.bat<0 then
		state="dead"
	end

end
